/* pages/wizard/wizard.wxss */
.wizard { padding-top: 8px; padding-bottom: 32px; }
.progress-bar {
  height: 4px; background: #e5e5ea; margin: 0 16px 12px; border-radius: 2px; overflow: hidden;
}
.progress-fill {
  height: 100%; background: #007aff; border-radius: 2px; transition: width 0.3s;
}

.step-card {
  background: #fff; border-radius: 14px; padding: 20px 16px;
  margin: 0 12px 12px; text-align: center;
}
.step-emoji { font-size: 36px; margin-bottom: 6px; }
.step-title { font-size: 18px; font-weight: 700; margin-bottom: 12px; }

.section-label {
  font-size: 11px; color: #8e8e93; font-weight: 600; text-align: left;
  margin: 14px 0 6px; text-transform: uppercase;
}

.chip-row {
  display: flex; gap: 6px; flex-wrap: wrap; justify-content: center; margin-bottom: 8px;
}
.chip {
  padding: 7px 14px; border-radius: 50px; border: 2px solid #e5e5ea;
  font-size: 13px; font-weight: 600; color: #1c1c1e; transition: all 0.15s;
}
.chip.active { background: #007aff; color: #fff; border-color: #007aff; }

.stepper {
  display: flex; align-items: center; justify-content: center; gap: 16px; padding: 8px 0;
}
.step-btn {
  width: 40px; height: 40px; border-radius: 50%; border: 2px solid #e5e5ea;
  display: flex; align-items: center; justify-content: center;
  font-size: 20px; font-weight: 700; color: #1c1c1e; background: #fff;
}
.step-val { font-size: 24px; font-weight: 800; min-width: 70px; text-align: center; }

.form-row {
  display: flex; align-items: center; gap: 8px; margin-bottom: 8px; font-size: 14px;
}
.form-label { flex-shrink: 0; min-width: 60px; text-align: left; color: #8e8e93; font-size: 13px; }
.form-input {
  flex: 1; padding: 8px 10px; border: 1.5px solid #e5e5ea; border-radius: 8px;
  font-size: 14px; text-align: right; background: #fdfaf7;
}
.form-unit { font-size: 12px; color: #8e8e93; flex-shrink: 0; }
.form-input.big { text-align: center; font-size: 18px; padding: 12px; }
.center-input { justify-content: center; }

.form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 6px; }
.form-grid .form-row { margin-bottom: 4px; }
.form-grid .form-label { min-width: 40px; font-size: 12px; }
.form-grid .form-input { font-size: 13px; padding: 6px 8px; }
.form-grid .form-unit { font-size: 11px; }

.total-row {
  text-align: right; font-size: 13px; font-weight: 600; color: #007aff;
  padding: 8px 0 0; margin-top: 8px; border-top: 1px solid #f0f0f5;
}

.nav-bar {
  display: flex; align-items: center; justify-content: center; gap: 12px;
  padding: 12px 16px 24px;
}
.nav-btn {
  padding: 10px 20px; border-radius: 50px; font-size: 14px; font-weight: 700;
}
.nav-btn.secondary { background: #f2f2f7; color: #8e8e93; }
.nav-btn.primary { background: #007aff; color: #fff; }
.nav-btn.done {
  background: linear-gradient(135deg, #ff6b35, #f7931e); color: #fff;
  padding: 12px 28px; font-size: 15px;
}
.nav-count { font-size: 13px; color: #8e8e93; font-weight: 600; }
