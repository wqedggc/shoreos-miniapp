/* pages/dashboard/dashboard.wxss */
.dashboard { padding: 8px 0 24px; }

.welcome-card {
  background: #fff; border-radius: 14px; padding: 40px 24px;
  margin: 16px 12px; text-align: center;
}
.wc-emoji { font-size: 48px; margin-bottom: 12px; }
.wc-title { font-size: 18px; font-weight: 800; margin-bottom: 8px; }
.wc-desc { font-size: 13px; color: #8e8e93; line-height: 1.7; }

.highlight-card {
  background: linear-gradient(135deg, #ff6b35, #f7931e);
  border-radius: 14px; padding: 20px; margin: 0 12px 10px; color: #fff;
  text-align: center;
}
.hl-emoji { font-size: 32px; margin-bottom: 6px; }
.hl-value { font-size: 36px; font-weight: 900; }
.hl-label { font-size: 13px; opacity: 0.85; margin-top: 2px; }
.hl-meta { font-size: 11px; opacity: 0.7; margin-top: 10px; display: flex; gap: 16px; justify-content: center; }

.metrics { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin: 0 12px 10px; }
.metric {
  background: #fff; border-radius: 14px; padding: 14px; text-align: center;
}
.m-emoji { font-size: 22px; margin-bottom: 4px; }
.m-val { font-size: 22px; font-weight: 800; }
.m-lbl { font-size: 10px; color: #8e8e93; margin-top: 2px; }
.m-sub { font-size: 9px; color: #8e8e93; margin-top: 1px; }
.green .m-val { color: #34c759; }
.blue .m-val { color: #007aff; }
.orange .m-val { color: #ff9500; }
.red .m-val { color: #ff3b30; }

.card {
  background: #fff; border-radius: 14px; padding: 14px; margin: 0 12px 10px;
}
.card-title { font-size: 14px; font-weight: 700; margin-bottom: 10px; }

.table-header, .table-row {
  display: flex; font-size: 11px; padding: 6px 0;
  border-bottom: 1px solid #f0f0f5;
}
.table-header { font-weight: 600; color: #8e8e93; border-bottom-width: 2px; }
.w1 { flex: 2; } .w2 { flex: 1; text-align: center; }
.w3 { flex: 1.5; text-align: right; } .w4 { flex: 1.5; text-align: right; }
.w5 { flex: 2; text-align: center; } .w6 { flex: 1.5; text-align: right; }
.hi { color: #007aff; font-weight: 700; }
.ok { color: #34c759; font-weight: 600; }
.wn { color: #ff9500; font-weight: 600; }

.hint {
  text-align: center; font-size: 12px; color: #8e8e93; padding: 12px;
}
